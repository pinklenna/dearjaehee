---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);

const mugsangPosts = sortedPosts.filter(({ data }) =>
  data.tags?.includes("묵상")
);
const gemPosts = sortedPosts.filter(({ data }) =>
  data.tags?.includes("with Gem")
);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Dear 재희
      </h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="inline-block"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <IconRss
          width={20}
          height={20}
          class="scale-125 stroke-accent stroke-3 rtl:-rotate-90"
        />
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        성경을 읽다가 드는 생각들, 그리고 AI와 함께 만들어가는 것들을 기록하는 공간이에요.
      </p>
      {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={["pt-12 pb-6", "border-b border-border"]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">주목할 글</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      mugsangPosts.length > 0 && (
        <section
          id="mugsang"
          class:list={["pt-12 pb-6", "border-b border-border"]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">묵상</h2>
          <ul>
            {mugsangPosts
              .slice(0, SITE.postPerIndex)
              .map(data => (
                <Card variant="h3" {...data} />
              ))}
          </ul>
          <div class="my-4 text-right">
            <LinkButton href="/tags/묵상/">
              더 보기
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    {
      gemPosts.length > 0 && (
        <section id="gem" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">
            성경공부 with Gem
          </h2>
          <ul>
            {gemPosts
              .slice(0, SITE.postPerIndex)
              .map(data => (
                <Card variant="h3" {...data} />
              ))}
          </ul>
          <div class="my-4 text-right">
            <LinkButton href="/tags/with-gem/">
              더 보기
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        전체 글 보기
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
